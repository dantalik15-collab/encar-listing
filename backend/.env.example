# Приложение
APP_NAME=Encar Listing
DEBUG=false

# База данных
DATABASE_URL=postgresql+asyncpg://encar:encar@db:5432/encar

# Парсер ENCAR
ENCAR_BASE_URL=http://api.encar.com/search/car/list/premium
SCRAPER_PAGE_SIZE=20
SCRAPER_MAX_PAGES=5
SCRAPER_DELAY_SECONDS=1.5
SCRAPER_MAX_RETRIES=3

# Планировщик (час:минута UTC)
SCRAPER_CRON_HOUR=3
SCRAPER_CRON_MINUTE=0

# Курс KRW → USD
KRW_TO_USD_RATE=0.00074
